{
  "name": "@wow-threat/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "fmt": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "kv:reset:local": "rm -rf .wrangler/state"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.46.0",
    "@wow-threat/config": "workspace:*",
    "@wow-threat/engine": "workspace:*",
    "@wow-threat/shared": "workspace:*",
    "@wow-threat/wcl-types": "workspace:*",
    "hono": "^4.12.9",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@cloudflare/workers-types": "^4.20260329.1",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^8.0.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "@wow-threat/typescript-config": "workspace:*",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.70.0"
  }
}
